# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database_name

# Google OAuth Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Session Security
JWT_SECRET=your-secure-random-jwt-secret-at-least-32-chars

# Cron / Automation Security
CRON_SECRET=your-secure-random-cron-secret-key

# UploadThing CDN Configuration
UPLOADTHING_TOKEN=your-uploadthing-token
UPLOADTHING_SECRET=your-uploadthing-secret-key

# Rate Limiting (Upstash Redis — required for multi-instance / serverless deployments)
# Create a free database at https://console.upstash.com and copy the REST URL + token.
# Without these vars the rate limiter falls back to fail-open (no limiting) — safe for
# local dev, but MUST be configured in staging and production.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Environment
NODE_ENV=development
